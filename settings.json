{
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.4",
  "defaultThinkingLevel": "high",
  "theme": "ghostty-sync-6c1158ac",
  "quietStartup": true,
  "doubleEscapeAction": "tree",
  "compaction": {
    "enabled": true,
    "reserveTokens": 16384,
    "keepRecentTokens": 20000
  },
  "retry": {
    "enabled": true,
    "maxRetries": 3,
    "baseDelayMs": 2000,
    "maxDelayMs": 60000
  },
  "enabledModels": ["claude-opus-4-6", "claude-sonnet-4-6", "claude-haiku-4-5"],
  "lastChangelogVersion": "0.65.2",
  "npmCommand": ["nix", "shell", "nixpkgs#nodejs", "-c", "npm"],
  "packages": [
    "git:github.com/nicobailon/pi-mcp-adapter",
    {
      "source": "git:github.com/prateekmedia/pi-hooks",
      "extensions": [
        "+lsp/lsp.ts",
        "+lsp/lsp-tool.ts"
      ]
    }
  ]
}
