    "lint:fix": "biome check --fix --config-path ../../biome.json src"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ],
    "skills": [
      "./skills"
    ],
    "image": "https://github.com/tintinweb/pi-gitnexus/raw/master/media/screenshot.png"
  },
  "piVendor": {
    "upstream": "https://github.com/tintinweb/pi-gitnexus",
    "commit": "db34bccdd29ee29f9185edb131a9ba0feb18d441",
    "localTarget": "extensions/gitnexus",
    "adaptedFor": "panda-harness extensions layout"
  }
}
