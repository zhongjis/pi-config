{
  "name": "panda-harness",
  "private": true,
  "description": "Personal Pi harness for extension development, testing, and AI-assisted maintenance.",
  "type": "module",
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "test": "vitest run",
    "test:extensions": "vitest run --project unit",
    "test:extensions:watch": "vitest --project unit",
    "test:integration": "vitest run --project integration",
    "lint": "biome check",
    "typecheck": "pnpm exec tsc --noEmit -p tsconfig.json",
    "lint:typecheck": "node ./scripts/lint-typecheck.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.5",
    "@marcfargas/pi-test-harness": "git+https://github.com/marcfargas/pi-test-harness.git",
    "@mariozechner/pi-agent-core": "^0.67.0",
    "@mariozechner/pi-ai": "^0.67.0",
    "@mariozechner/pi-coding-agent": "^0.67.0",
    "@sinclair/typebox": "^0.34.41",
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.7"
  },
  "pnpm": {
    "patchedDependencies": {
      "@marcfargas/pi-test-harness@0.5.0": "patches/@marcfargas__pi-test-harness@0.5.0.patch"
    }
  }
}
