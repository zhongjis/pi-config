<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ page.title }}</title>
    <link rel="stylesheet" href="{{ stylesheet_href }}">
  </head>
  <body>
    <header class="page-header">
      <div>
        <p class="eyebrow">Module 2</p>
        <h1>{{ page.title }}</h1>
        <p class="lede">Landing view stays focused on triage first. Session Detail follows the current top-priority session. Baseline Comparison stays explicit: no baseline is chosen unless you render one deliberately.</p>
      </div>
      <dl class="meta-grid">
        <div>
          <dt>Persisted session exports</dt>
          <dd>{{ page.session_count }}</dd>
        </div>
        <div>
          <dt>Input root</dt>
          <dd class="mono">{{ page.input_root }}</dd>
        </div>
        <div>
          <dt>Generated at</dt>
          <dd class="mono">{{ page.generated_at }}</dd>
        </div>
      </dl>
      <div class="caveat-banner">
        <strong>Contract gap:</strong>
        <span>{{ page.session_list.contract_gap_note }}</span>
      </div>
    </header>

    <main class="page-grid">
      <section class="panel session-list-panel">
        <div class="section-heading">
          <div>
            <p class="eyebrow">Landing view</p>
            <h2>Session List</h2>
            <p class="section-copy">{{ page.session_list.queue_note }}</p>
          </div>
          {% if page.session_list.rows %}
            <dl class="summary-grid">
              <div>
                <dt>Rows</dt>
                <dd>{{ page.session_list.row_count }}</dd>
              </div>
              <div>
                <dt>Need review</dt>
                <dd>{{ page.session_list.review_count }}</dd>
              </div>
              <div>
                <dt>Baseline path</dt>
                <dd>Explicit rerender</dd>
              </div>
            </dl>
          {% endif %}
        </div>

        {% if page.session_list.rows %}
          <section class="queue-block">
            <div class="queue-header">
              <h3>Triage Queue</h3>
              <p>Review these sessions before drilling into the focused detail and optional comparison below.</p>
            </div>
            <ul class="queue-list">
              {% for row in page.session_list.queue_rows %}
                <li class="queue-item">
                  <div class="queue-main">
                    <div class="queue-title-row">
                      <span class="mono queue-id">{{ row.session_id }}</span>
                      <span class="subtle">{{ row.project_label }}</span>
                    </div>
                    <div class="queue-meta">
                      <span class="mono">{{ row.timestamp_label }}</span>
                      <span class="confidence confidence-{{ row.confidence_tone }}">{{ row.confidence_label }}</span>
                      {% for badge in row.badges %}
                        <span class="badge badge-{{ badge.tone }}">{{ badge.label }}</span>
                      {% endfor %}
                    </div>
                    <p class="subtle queue-note">{{ row.confidence_note }}</p>
                  </div>
                  <div class="queue-action">
                    <span class="selection-hint mono">{{ row.baseline_action_label }}</span>
                    <p class="subtle">{{ row.baseline_action_note }}</p>
                  </div>
                </li>
              {% endfor %}
            </ul>
          </section>

          <section class="table-block">
            <div class="queue-header">
              <h3>Session Table</h3>
              <p>All required Session List columns are visible in the landing view.</p>
            </div>
            <div class="table-wrap">
              <table class="session-table">
                <thead>
                  <tr>
                    <th>Timestamp</th>
                    <th>Session ID</th>
                    <th>Project / CWD</th>
                    <th>Source</th>
                    <th>Config Version</th>
                    <th>Duration</th>
                    <th>Billed Tokens</th>
                    <th>Cost (USD)</th>
                    <th>Tool Success</th>
                    <th>Error→Retry</th>
                    <th>Incomplete</th>
                    <th>Unknown Records</th>
                    <th>Confidence</th>
                    <th>Alerts</th>
                    <th>Baseline path</th>
                  </tr>
                </thead>
                <tbody>
                  {% for row in page.session_list.rows %}
                    <tr>
                      <td class="mono">{{ row.timestamp_label }}</td>
                      <td class="mono">{{ row.session_id }}</td>
                      <td>
                        <div class="cell-stack">
                          <span>{{ row.project_label }}</span>
                          <span class="subtle mono">{{ row.cwd_label }}</span>
                        </div>
                      </td>
                      <td>
                        <div class="cell-stack">
                          <span class="contract-gap">{{ row.source_label }}</span>
                          <span class="subtle">{{ row.source_note }}</span>
                        </div>
                      </td>
                      <td>
                        <div class="cell-stack">
                          <span class="contract-gap">{{ row.config_version_label }}</span>
                          <span class="subtle">{{ row.config_version_note }}</span>
                        </div>
                      </td>
                      <td class="mono">{{ row.total_duration_label }}</td>
                      <td class="mono">{{ row.total_billed_tokens_label }}</td>
                      <td class="mono">{{ row.total_cost_label }}</td>
                      <td class="mono">{{ row.tool_success_rate_label }}</td>
                      <td class="mono">{{ row.error_then_retry_count_label }}</td>
                      <td>{{ row.incomplete_label }}</td>
                      <td class="mono">{{ row.unknown_record_count_label }}</td>
                      <td>
                        <div class="cell-stack">
                          <span class="confidence confidence-{{ row.confidence_tone }}">{{ row.confidence_label }}</span>
                          <span class="subtle">{{ row.confidence_note }}</span>
                        </div>
                      </td>
                      <td>
                        {% if row.badges %}
                          <div class="badge-list">
                            {% for badge in row.badges %}
                              <span class="badge badge-{{ badge.tone }}">{{ badge.label }}</span>
                            {% endfor %}
                          </div>
                        {% else %}
                          <span class="subtle">None</span>
                        {% endif %}
                      </td>
                      <td>
                        <div class="cell-stack">
                          <span class="selection-hint mono">{{ row.baseline_action_label }}</span>
                          <span class="subtle">{{ row.baseline_action_note }}</span>
                        </div>
                      </td>
                    </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>
          </section>
        {% else %}
          <div class="empty-state">
            <h3>{{ page.session_list.empty_title }}</h3>
            <p>{{ page.session_list.empty_description }}</p>
          </div>
        {% endif %}
      </section>

      <section class="panel detail-panel">
        <div class="section-heading">
          <div>
            <p class="eyebrow">Focused session</p>
            <h2>Session Detail</h2>
          </div>
        </div>

        {% if page.session_detail.status == "ready" %}
          <div class="detail-header">
            <div class="focus-summary">
              <span class="mono queue-id">{{ page.session_detail.focused_session_id }}</span>
              <span>{{ page.session_detail.focused_project_label }}</span>
              <span class="mono subtle">{{ page.session_detail.focused_timestamp_label }}</span>
              <span class="confidence confidence-{{ page.session_detail.confidence_tone }}">{{ page.session_detail.confidence_label }}</span>
            </div>
            <p class="subtle">{{ page.session_detail.focus_reason }}</p>
          </div>

          <dl class="kpi-grid">
            {% for metric in page.session_detail.headline_metrics %}
              <div class="metric-card">
                <dt>{{ metric.label }}</dt>
                <dd class="mono">{{ metric.value }}</dd>
                <p class="metric-note">{{ metric.note }}</p>
              </div>
            {% endfor %}
          </dl>

          <div class="detail-grid">
            <section class="detail-card">
              <h3>Timing</h3>
              <dl class="detail-list">
                {% for field in page.session_detail.timing_fields %}
                  <div>
                    <dt>{{ field.label }}</dt>
                    <dd class="mono">{{ field.value }}</dd>
                    {% if field.note %}
                      <p class="detail-note">{{ field.note }}</p>
                    {% endif %}
                  </div>
                {% endfor %}
              </dl>
            </section>

            <section class="detail-card">
              <h3>Token totals</h3>
              <dl class="detail-list">
                {% for field in page.session_detail.token_fields %}
                  <div>
                    <dt>{{ field.label }}</dt>
                    <dd class="mono">{{ field.value }}</dd>
                    {% if field.note %}
                      <p class="detail-note">{{ field.note }}</p>
                    {% endif %}
                  </div>
                {% endfor %}
              </dl>
            </section>

            <section class="detail-card">
              <h3>Tool reliability</h3>
              <dl class="detail-list">
                {% for field in page.session_detail.tool_fields %}
                  <div>
                    <dt>{{ field.label }}</dt>
                    <dd class="mono">{{ field.value }}</dd>
                    {% if field.note %}
                      <p class="detail-note">{{ field.note }}</p>
                    {% endif %}
                  </div>
                {% endfor %}
              </dl>
            </section>

            <section class="detail-card">
              <h3>Extraction confidence</h3>
              <dl class="detail-list">
                {% for field in page.session_detail.extraction_fields %}
                  <div>
                    <dt>{{ field.label }}</dt>
                    {% if field.label == "Confidence" %}
                      <dd><span class="confidence confidence-{{ page.session_detail.confidence_tone }}">{{ field.value }}</span></dd>
                    {% else %}
                      <dd class="mono">{{ field.value }}</dd>
                    {% endif %}
                    {% if field.note %}
                      <p class="detail-note">{{ field.note }}</p>
                    {% endif %}
                  </div>
                {% endfor %}
              </dl>
            </section>
          </div>
        {% else %}
          <div class="empty-state">
            <h3>{{ page.session_detail.empty_title }}</h3>
            <p>{{ page.session_detail.empty_description }}</p>
          </div>
        {% endif %}
      </section>

      <section class="panel comparison-panel">
        <div class="section-heading">
          <div>
            <p class="eyebrow">List → Detail → Compare</p>
            <h2>Baseline Comparison</h2>
            <p class="section-copy">{{ page.baseline_comparison.choice_path_note }}</p>
          </div>
        </div>

        {% if page.baseline_comparison.status == "ready" %}
          <div class="comparison-summary-grid">
            <div class="detail-card">
              <h3>Selected session</h3>
              <p class="mono queue-id">{{ page.baseline_comparison.selected_session_id }}</p>
              <p>{{ page.baseline_comparison.selected_project_label }}</p>
              <p class="mono subtle">{{ page.baseline_comparison.selected_timestamp_label }}</p>
            </div>
            <div class="detail-card">
              <h3>Chosen baseline</h3>
              <p class="mono queue-id">{{ page.baseline_comparison.baseline_session_id }}</p>
              <p>{{ page.baseline_comparison.baseline_project_label }}</p>
              <p class="mono subtle">{{ page.baseline_comparison.baseline_timestamp_label }}</p>
            </div>
            <div class="detail-card">
              <h3>Comparison fit</h3>
              <p class="comparison-fit comparison-fit-{{ page.baseline_comparison.fit_tone }}">{{ page.baseline_comparison.fit_label }}</p>
              <p class="detail-note">{{ page.baseline_comparison.fit_note }}</p>
            </div>
          </div>

          <div class="comparison-caveats">
            {% for caveat in page.baseline_comparison.caveats %}
              <div class="caveat-banner">
                <strong>Caveat:</strong>
                <span>{{ caveat }}</span>
              </div>
            {% endfor %}
          </div>

          <div class="comparison-grid">
            {% for metric in page.baseline_comparison.metrics %}
              <section class="detail-card comparison-metric comparison-tone-{{ metric.tone }}">
                <h3>{{ metric.label }}</h3>
                <dl class="comparison-values">
                  <div>
                    <dt>Selected</dt>
                    <dd class="mono">{{ metric.selected_value }}</dd>
                  </div>
                  <div>
                    <dt>Baseline</dt>
                    <dd class="mono">{{ metric.baseline_value }}</dd>
                  </div>
                  <div>
                    <dt>Absolute delta</dt>
                    <dd class="mono">{{ metric.absolute_delta }}</dd>
                  </div>
                  <div>
                    <dt>Percent delta</dt>
                    <dd class="mono">{{ metric.percent_delta }}</dd>
                  </div>
                </dl>
                <p class="comparison-direction comparison-direction-{{ metric.tone }}">{{ metric.direction_label }}</p>
                <div class="delta-bar-track">
                  <div class="delta-bar-fill delta-bar-fill-{{ metric.tone }}" style="width: {{ metric.bar_width }}%"></div>
                </div>
                <p class="detail-note">{{ metric.note }}</p>
              </section>
            {% endfor %}
          </div>
        {% else %}
          <div class="empty-state">
            <h3>{{ page.baseline_comparison.empty_title }}</h3>
            <p>{{ page.baseline_comparison.empty_description }}</p>
          </div>
        {% endif %}

        {% if page.baseline_comparison.candidates %}
          <section class="comparison-candidates-block">
            <div class="queue-header">
              <h3>Explicit baseline choices</h3>
              <p>These candidates are ranked from real project, extraction-health, and timestamp signals only.</p>
            </div>
            <ul class="comparison-candidates">
              {% for candidate in page.baseline_comparison.candidates %}
                <li class="comparison-candidate {% if candidate.is_selected %}comparison-candidate-selected{% endif %}">
                  <div class="queue-main">
                    <div class="queue-title-row">
                      <span class="mono queue-id">{{ candidate.session_id }}</span>
                      <span class="subtle">{{ candidate.project_label }}</span>
                    </div>
                    <p class="subtle mono">{{ candidate.timestamp_label }}</p>
                    <p class="subtle">{{ candidate.rank_note }}</p>
                  </div>
                  <div class="queue-action">
                    <span class="selection-hint mono">{{ candidate.choice_label }}</span>
                    <p class="subtle">{{ candidate.choice_note }}</p>
                  </div>
                </li>
              {% endfor %}
            </ul>
          </section>
        {% endif %}
      </section>
    </main>
  </body>
</html>
